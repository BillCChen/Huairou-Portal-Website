SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=180
DATABASE_URL=sqlite:///app/data/portal_test.db
INIT_SAMPLE_DATA=true
CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100,http://localhost:5174,http://127.0.0.1:5174
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
SMS_TEST_CODE=123456
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_DEV_OUTBOX_DIR=/app/data/tmp/mail_outbox
PUBLIC_FRONTEND_BASE_URL=http://127.0.0.1:3100
EMAIL_PROVIDER=dev_outbox
