# Portal production deployment env example.
# Copy this file to deploy/docker/.env.production on the server.
# Never commit deploy/docker/.env.production.

POSTGRES_DB=portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=CHANGE_ME

PORTAL_SECRET_KEY=CHANGE_ME
PORTAL_ADMIN_USERNAME=admin
PORTAL_ADMIN_PASSWORD=CHANGE_ME
PORTAL_SMS_TEST_CODE=000000

PORTAL_API_HOST_PORT=18100
PORTAL_WEB_HOST_PORT=13100
PORTAL_ADMIN_HOST_PORT=15174

PORTAL_CORS_ORIGINS=https://huairou.tech,https://www.huairou.tech,https://portal-admin.huairou.tech

PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_DEV_OUTBOX_DIR=/app/data/tmp/mail_outbox
PUBLIC_FRONTEND_BASE_URL=https://huairou.tech

EMAIL_PROVIDER=dev_outbox

# Enable only for controlled SMTP UAT or production email.
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USERNAME=no-reply@notify.inside-chen.top
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=no-reply@notify.inside-chen.top
SMTP_FROM_NAME=Portal Website
SMTP_USE_TLS=true
SMTP_USE_STARTTLS=false
SMTP_TIMEOUT_SECONDS=10
SMTP_REQUIRE_AUTH=true

PORTAL_WEB_PUBLIC_API_BASE=https://huairou.tech/api/v1
PORTAL_ADMIN_API_BASE=https://huairou.tech/api/v1

PORTAL_POSTGRES_IMAGE=postgres:16
