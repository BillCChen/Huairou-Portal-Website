PORTAL_SECRET_KEY=replace-with-a-random-64-char-string
PORTAL_ADMIN_PASSWORD=replace-with-a-strong-password
PORTAL_SMS_TEST_CODE=replace-with-your-sms-test-code
POSTGRES_PASSWORD=replace-with-db-password
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_DEV_OUTBOX_DIR=/app/data/tmp/mail_outbox
PUBLIC_FRONTEND_BASE_URL=https://portal.example.com
EMAIL_PROVIDER=dev_outbox
# EMAIL_PROVIDER=smtp requires these SMTP values and a runtime-injected secret.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USERNAME=no-reply@example.com
# SMTP_PASSWORD=CHANGE_ME
# SMTP_FROM_EMAIL=no-reply@example.com
# SMTP_FROM_NAME=Portal Website
# SMTP_USE_TLS=true
# SMTP_USE_STARTTLS=false
# SMTP_TIMEOUT_SECONDS=10
# SMTP_REQUIRE_AUTH=true
DATABASE_URL=postgresql+psycopg://portal:replace-with-db-password@postgres:5432/portal
